# SOPS configuration file
# Auto-generated by Ansible sops_age role
# Last updated: {{ ansible_date_time.iso8601 | default(lookup('pipe', 'date -Iseconds')) }}

keys:
  # Admin key (for encryption from your workstation)
  - &admin {{ sops_age_admin_public_key }}
{% for host_name, host_key in sops_update_host_keys.items() %}
  # {{ host_name }} host key
  - &{{ host_name | replace('-', '_') }} {{ host_key }}
{% endfor %}

creation_rules:
  # All secrets - encrypted for admin + all hosts
  - path_regex: secrets/.*\.yaml$
    key_groups:
      - age:
          - *admin
{% for host_name, host_key in sops_update_host_keys.items() %}
          - *{{ host_name | replace('-', '_') }}
{% endfor %}
