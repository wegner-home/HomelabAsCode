#!/usr/bin/env bash
# SSH Host Certificate Signing Script
# Generated by Ansible ssh_ca role — DO NOT EDIT MANUALLY
#
# Usage: {{ ssh_ca_dir }}/sign-host-cert.sh <host_public_key_file> <hostname> [additional_principals]
#
# Example:
#   ./sign-host-cert.sh /etc/ssh/ssh_host_ed25519_key.pub myhost
#   ./sign-host-cert.sh /etc/ssh/ssh_host_ed25519_key.pub myhost "myhost.lan.wegner.cool,10.10.10.5"

set -euo pipefail

CA_KEY="{{ ssh_ca_dir }}/{{ ssh_ca_key_name }}"
VALIDITY="{{ ssh_ca_host_cert_validity }}"
DOMAIN="{{ ssh_ca_domain }}"

if [ $# -lt 2 ]; then
    echo "Usage: $0 <host_public_key_file> <hostname> [additional_principals]"
    echo ""
    echo "Arguments:"
    echo "  host_public_key_file   Path to the host's SSH public key (e.g. /etc/ssh/ssh_host_ed25519_key.pub)"
    echo "  hostname               Short hostname of the machine"
    echo "  additional_principals  Optional: extra hostnames/IPs (comma-separated)"
    echo ""
    echo "The certificate will include these principals:"
    echo "  <hostname>, <hostname>.$DOMAIN"
    echo "  Plus any additional_principals if provided"
    echo ""
    echo "Example:"
    echo "  $0 /etc/ssh/ssh_host_ed25519_key.pub myhost"
    echo "  $0 /etc/ssh/ssh_host_ed25519_key.pub myhost \"10.10.10.5,myhost.other.domain\""
    exit 1
fi

HOST_PUB_KEY="$1"
HOSTNAME="$2"
EXTRA_PRINCIPALS="${3:-}"

# Build principals list: short name + FQDN + any extras
PRINCIPALS="${HOSTNAME},${HOSTNAME}.${DOMAIN}"
if [ -n "$EXTRA_PRINCIPALS" ]; then
    PRINCIPALS="${PRINCIPALS},${EXTRA_PRINCIPALS}"
fi

IDENTITY="host:${HOSTNAME}.${DOMAIN}"

if [ ! -f "$HOST_PUB_KEY" ]; then
    echo "ERROR: Host public key file not found: $HOST_PUB_KEY"
    exit 1
fi

if [ ! -f "$CA_KEY" ]; then
    echo "ERROR: CA key not found: $CA_KEY"
    exit 1
fi

echo "Signing host certificate:"
echo "  Host key:    $HOST_PUB_KEY"
echo "  Principals:  $PRINCIPALS"
echo "  Identity:    $IDENTITY"
echo "  Validity:    $VALIDITY"
echo ""

ssh-keygen -s "$CA_KEY" \
    -I "$IDENTITY" \
    -h \
    -n "$PRINCIPALS" \
    -V "$VALIDITY" \
    "$HOST_PUB_KEY"

CERT_FILE="${HOST_PUB_KEY%.pub}-cert.pub"
echo ""
echo "Host certificate created: $CERT_FILE"
echo ""
ssh-keygen -L -f "$CERT_FILE"
