#!/usr/bin/env bash
# SSH User Certificate Signing Script
# Generated by Ansible ssh_ca role — DO NOT EDIT MANUALLY
#
# Usage: {{ ssh_ca_dir }}/sign-user-cert.sh <public_key_file> <principal> [identity]
#
# Example:
#   ./sign-user-cert.sh ~/.ssh/id_ed25519.pub phil "phil@{{ project_name }}"
#   ./sign-user-cert.sh /tmp/user.pub deploy "deploy-key"

set -euo pipefail

CA_KEY="{{ ssh_ca_dir }}/{{ ssh_ca_key_name }}"
VALIDITY="{{ ssh_ca_user_cert_validity }}"

if [ $# -lt 2 ]; then
    echo "Usage: $0 <public_key_file> <principal> [identity]"
    echo ""
    echo "Arguments:"
    echo "  public_key_file  Path to the user's SSH public key"
    echo "  principal        Username(s) the cert is valid for (comma-separated)"
    echo "  identity         Optional: certificate identity string (default: principal@{{ ssh_ca_domain }})"
    echo ""
    echo "Example:"
    echo "  $0 ~/.ssh/id_ed25519.pub phil"
    echo "  $0 ~/.ssh/id_ed25519.pub phil,admin \"phil-workstation\""
    exit 1
fi

PUB_KEY="$1"
PRINCIPAL="$2"
IDENTITY="${3:-${PRINCIPAL%%,*}@{{ ssh_ca_domain }}}"

if [ ! -f "$PUB_KEY" ]; then
    echo "ERROR: Public key file not found: $PUB_KEY"
    exit 1
fi

if [ ! -f "$CA_KEY" ]; then
    echo "ERROR: CA key not found: $CA_KEY"
    exit 1
fi

echo "Signing user certificate:"
echo "  Public key:  $PUB_KEY"
echo "  Principal:   $PRINCIPAL"
echo "  Identity:    $IDENTITY"
echo "  Validity:    $VALIDITY"
echo ""

ssh-keygen -s "$CA_KEY" \
    -I "$IDENTITY" \
    -n "$PRINCIPAL" \
    -V "$VALIDITY" \
    "$PUB_KEY"

CERT_FILE="${PUB_KEY%.pub}-cert.pub"
echo ""
echo "Certificate created: $CERT_FILE"
echo ""
ssh-keygen -L -f "$CERT_FILE"
