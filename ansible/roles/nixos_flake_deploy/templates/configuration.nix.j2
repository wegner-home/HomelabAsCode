{ config, pkgs, lib, ... }:

{
  # NixOS Configuration for {{ nixos_host_fqdn }}
  # Role: {{ nixos_host_role }}
  # Generated by Ansible - changes will be overwritten

  imports = [
    ./hardware-configuration.nix
  ];

  # ===============================================
  # System Configuration
  # ===============================================
  system.stateVersion = "{{ nixos_state_version | default('25.11') }}";

  networking = {
    hostName = "{{ nixos_host_hostname }}";
    domain = "{{ nixos_host_domain }}";

    # Use systemd-networkd
    useNetworkd = true;
    useDHCP = false;

    # Firewall
    firewall = {
      enable = {{ nixos_host_firewall_enable | lower }};
      allowedTCPPorts = {{ nixos_host_firewall_allowed_tcp_ports | to_json }};
    };
  };

  # ===============================================
  # Nix Configuration
  # ===============================================
  nix = {
    settings = {
      experimental-features = [ "nix-command" "flakes" ];
      auto-optimise-store = {{ nixos_host_enable_node_exporter | default(true) | lower }};
    };

    gc = {
      automatic = true;
      dates = "daily";
      options = "--delete-older-than 7d";
    };
  };

  # ===============================================
  # Time & Locale
  # ===============================================
  time.timeZone = "{{ global_timezone | default('UTC') }}";
  i18n.defaultLocale = "en_US.UTF-8";

  # ===============================================
  # User Management
  # ===============================================
  users.users = {
{% for user in nixos_host_users %}
    {{ user.name }} = {
      isNormalUser = true;
      description = "{{ user.description | default(user.name) }}";
      extraGroups = {{ user.groups | default(['wheel']) | to_json }};
      shell = {{ user.shell | default('pkgs.bash') }};
{% if user.ssh_authorized_keys is defined and user.ssh_authorized_keys %}
      openssh.authorizedKeys.keys = {{ user.ssh_authorized_keys | to_json }};
{% endif %}
    };
{% endfor %}
  };

  # ===============================================
  # SSH Configuration
  # ===============================================
  services.openssh = {
    enable = true;
    settings = {
      PermitRootLogin = "prohibit-password";
      PasswordAuthentication = false;
      KbdInteractiveAuthentication = false;
    };
{% if nixos_host_ssh_ca_enable %}
    # SSH CA trust configuration
    extraConfig = ''
      TrustedUserCAKeys {{ nixos_host_ssh_ca_dir }}/{{ nixos_host_ssh_ca_key_name }}.pub
    '';
{% endif %}
  };

  # ===============================================
  # System Packages
  # ===============================================
  environment.systemPackages = with pkgs; [
{% for package in nixos_host_all_packages %}
{% if '-' in package %}
    pkgs."{{ package }}"
{% else %}
    {{ package }}
{% endif %}
{% endfor %}
  ];

  # ===============================================
  # Monitoring
  # ===============================================
{% if nixos_host_enable_node_exporter %}
  services.prometheus.exporters.node = {
    enable = true;
    port = {{ nixos_host_node_exporter_port }};
    enabledCollectors = [ "systemd" ];
  };
{% endif %}

  # ===============================================
  # SOPS/Age Secrets
  # ===============================================
{% if nixos_host_sops_enable %}
  sops = {
    defaultSopsFile = {{ nixos_host_sops_default_sops_file }};
    age.keyFile = "{{ nixos_host_sops_age_key_file }}";
{% if nixos_host_role == 'gitlab' %}
    secrets = {
      gitlab-root-password = { owner = "gitlab"; };
      gitlab-db-password = { owner = "gitlab"; };
      gitlab-db-secret = { owner = "gitlab"; };
      gitlab-secret = { owner = "gitlab"; };
      gitlab-otp = { owner = "gitlab"; };
      gitlab-jws = { owner = "gitlab"; };
      gitlab-ar-primary = { owner = "gitlab"; };
      gitlab-ar-deterministic = { owner = "gitlab"; };
      gitlab-ar-salt = { owner = "gitlab"; };
{% if gitlab_runner_enable | default(false) %}
      gitlab-runner-token = { owner = "gitlab-runner"; };
{% endif %}
    };
{% endif %}
  };
{% endif %}

{% if nixos_host_enable_docker %}
  # ===============================================
  # Docker
  # ===============================================
  virtualisation.docker = {
    enable = true;
    autoPrune = {
      enable = true;
      dates = "weekly";
    };
  };
{% endif %}

{% if nixos_host_enable_tailscale %}
  # ===============================================
  # Tailscale VPN
  # ===============================================
  services.tailscale = {
    enable = true;
  };
{% endif %}

{% if nixos_host_role == 'gitlab' %}
  # ===============================================
  # GitLab CE/EE Configuration
  # ===============================================
  services.gitlab = {
    enable = true;

    # Basic settings
    host = "{{ nixos_host_fqdn }}";
    port = 443;
    https = {{ gitlab_ssl_enable | default(true) | lower }};

    # User and group
    user = "gitlab";
    group = "gitlab";

    # Initial root password
    initialRootPasswordFile = config.sops.secrets.gitlab-root-password.path;

    # Paths
    statePath = "/var/lib/gitlab";
    backup.path = "/var/lib/gitlab/backups";

    # Secrets
    databasePasswordFile = config.sops.secrets.gitlab-db-password.path;
    secrets = {
      dbFile = config.sops.secrets.gitlab-db-secret.path;
      secretFile = config.sops.secrets.gitlab-secret.path;
      otpFile = config.sops.secrets.gitlab-otp.path;
      jwsFile = config.sops.secrets.gitlab-jws.path;
      # ActiveRecord encryption keys (required for GitLab 18+)
      activeRecordPrimaryKeyFile = config.sops.secrets.gitlab-ar-primary.path;
      activeRecordDeterministicKeyFile = config.sops.secrets.gitlab-ar-deterministic.path;
      activeRecordSaltFile = config.sops.secrets.gitlab-ar-salt.path;
    };

    # Extra configuration
    extraConfig = {
      gitlab = {
        email_from = "{{ gitlab_email_from | default('gitlab@' + global_domain) }}";
        email_display_name = "{{ gitlab_email_display_name | default('GitLab @ ' + global_domain) }}";
        email_reply_to = "{{ gitlab_email_from | default('gitlab@' + global_domain) }}";
        signup_enabled = false;
        default_projects_features = {
          issues = true;
          merge_requests = true;
          wiki = true;
          snippets = true;
          builds = true;
          container_registry = {{ gitlab_enable_registry | default(true) | lower }};
        };
      };

      lfs = {
        enabled = {{ gitlab_enable_lfs | default(true) | lower }};
      };

{% if gitlab_enable_prometheus | default(true) %}
      prometheus = {
        enable = true;
        listen_address = "localhost:{{ gitlab_prometheus_port | default(9090) }}";
      };
{% endif %}
    };

    # Performance settings
    puma.workers = {{ gitlab_puma_worker_processes | default(2) }};
    sidekiq.concurrency = {{ gitlab_sidekiq_concurrency | default(10) }};
  };

{% if gitlab_enable_registry | default(true) %}
  # GitLab Registry (JWT auth certs auto-generated by nixpkgs gitlab-registry-cert service)
  services.gitlab.registry = {
    enable = true;
    externalAddress = "registry.{{ nixos_host_fqdn }}";
    externalPort = {{ gitlab_registry_port | default(5050) }};
    certFile = "/var/lib/gitlab/registry/gitlab-registry.crt";
    keyFile = "/var/lib/gitlab/registry/gitlab-registry.key";
  };

  # docker-registry needs gitlab group to traverse /var/lib/gitlab/ (0750) and read JWT cert
  systemd.services.docker-registry.serviceConfig.SupplementaryGroups = [ "gitlab" ];
{% endif %}

  # nginx needs gitlab group to traverse /var/lib/gitlab/ (0750) and read SSL certs
  systemd.services.nginx.serviceConfig.SupplementaryGroups = [ "gitlab" ];

  # ===============================================
  # SSL/TLS — Nginx Reverse Proxy
  # ===============================================
  systemd.services.gitlab-ensure-cert = {
    description = "Ensure SSL certificate exists for GitLab";
    wantedBy = [ "multi-user.target" ];
    before = [ "nginx.service" ];
    requiredBy = [ "nginx.service" ];
    serviceConfig = {
      Type = "oneshot";
      RemainAfterExit = true;
    };
    path = [ pkgs.openssl ];
    script = ''
      CERT="/var/lib/gitlab/ssl/gitlab.crt"
      KEY="/var/lib/gitlab/ssl/gitlab.key"
      LOCAL_CERT="/etc/nixos/secrets/gitlab-ssl-cert.crt"
      LOCAL_KEY="/etc/nixos/secrets/gitlab-ssl-cert.key"

      # If both cert and key already exist at the target path, nothing to do
      if [ -f "$CERT" ] && [ -f "$KEY" ]; then
        echo "SSL certificate already exists at $CERT"
        exit 0
      fi

      mkdir -p "$(dirname "$CERT")"

      # If a local certificate was provided in the flake, use it
      if [ -f "$LOCAL_CERT" ] && [ -f "$LOCAL_KEY" ]; then
        echo "Using local certificate from $LOCAL_CERT"
        cp "$LOCAL_CERT" "$CERT"
        cp "$LOCAL_KEY" "$KEY"
        chmod 640 "$KEY"
        chmod 644 "$CERT"
        chown root:nginx "$KEY"
        echo "Local certificate installed for {{ nixos_host_fqdn }}"
        exit 0
      fi

      echo "No certificate found — generating self-signed certificate"
      openssl req -x509 -newkey rsa:4096 \
        -keyout "$KEY" \
        -out "$CERT" \
        -sha256 -days 3650 -nodes \
        -subj "/CN={{ nixos_host_fqdn }}" \
        -addext "subjectAltName=DNS:{{ nixos_host_fqdn }},DNS:registry.{{ nixos_host_fqdn }},DNS:gitlab.{{ nixos_host_domain }},DNS:git.{{ nixos_host_domain }},DNS:registry.{{ nixos_host_hostname }},DNS:pages.{{ nixos_host_hostname }}"
      chmod 640 "$KEY"
      chmod 644 "$CERT"
      chown root:nginx "$KEY"
      echo "Self-signed certificate generated for {{ nixos_host_fqdn }}"
    '';
  };

  services.nginx = {
    enable = true;
    recommendedProxySettings = true;
    recommendedTlsSettings = true;

    # GitLab web UI / API
    virtualHosts."{{ nixos_host_fqdn }}" = {
      forceSSL = true;
      serverAliases = [ "gitlab.{{ nixos_host_domain }}" "git.{{ nixos_host_domain }}" "registry.{{ nixos_host_hostname }}" "pages.{{ nixos_host_hostname }}" ];
      sslCertificate = "/var/lib/gitlab/ssl/gitlab.crt";
      sslCertificateKey = "/var/lib/gitlab/ssl/gitlab.key";
      locations."/" = {
        proxyPass = "http://unix:/run/gitlab/gitlab-workhorse.socket";
        proxyWebsockets = true;
        extraConfig = ''
          client_max_body_size 0;
          proxy_read_timeout 3600;
          proxy_connect_timeout 300;
        '';
      };
    };

{% if gitlab_enable_registry | default(true) %}
    # Container registry
    virtualHosts."registry.{{ nixos_host_fqdn }}" = {
      forceSSL = true;
      sslCertificate = "/var/lib/gitlab/ssl/gitlab.crt";
      sslCertificateKey = "/var/lib/gitlab/ssl/gitlab.key";
      locations."/" = {
        proxyPass = "http://127.0.0.1:{{ gitlab_registry_port | default(5050) }}";
        extraConfig = ''
          client_max_body_size 0;
          chunked_transfer_encoding on;
        '';
      };
    };
{% endif %}
  };

  # ===============================================
  # PostgreSQL Configuration
  # ===============================================
  services.postgresql = {
    enable = true;
    ensureDatabases = [ "gitlab" ];
    ensureUsers = [
      {
        name = "gitlab";
        ensureDBOwnership = true;
      }
    ];
    settings = {
      shared_buffers = "256MB";
      max_connections = 200;
    };
  };

  # ===============================================
  # Redis Configuration
  # ===============================================
  services.redis.servers.gitlab = {
    enable = true;
    port = 0; # Unix socket only (recommended)
  };

{% if gitlab_backup_enable | default(true) %}
  # ===============================================
  # Backup Configuration (uses nixpkgs built-in gitlab-backup service)
  # ===============================================
  services.gitlab.backup = {
    startAt = "{{ gitlab_backup_schedule | default('02:00') }}";
    skip = [ "uploads" ];
    keepTime = {{ (gitlab_backup_retention | default(7)) * 24 }}; # hours
  };
{% endif %}
{% endif %}
}
