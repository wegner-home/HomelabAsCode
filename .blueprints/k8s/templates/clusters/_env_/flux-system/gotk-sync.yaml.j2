---
# FluxCD GitRepository - points to this repo
# Generated by blueprint_repo — DO NOT EDIT MANUALLY
apiVersion: source.toolkit.fluxcd.io/v1
kind: GitRepository
metadata:
  name: flux-system
  namespace: flux-system
spec:
  interval: 1m0s
  ref:
    branch: {{ blueprint_repo_context.fluxcd_git_branch }}
  secretRef:
    name: flux-system
  url: {{ blueprint_repo_context.fluxcd_git_repo }}
---
# Root Kustomization - reconciles the cluster directory
apiVersion: kustomize.toolkit.fluxcd.io/v1
kind: Kustomization
metadata:
  name: flux-system
  namespace: flux-system
spec:
  interval: 10m0s
  path: ./clusters/{{ blueprint_env }}
  prune: true
  sourceRef:
    kind: GitRepository
    name: flux-system
