---
# Docker Compose Auto-Deploy Pipeline
# Generated by blueprint_repo — DO NOT EDIT MANUALLY
# Regenerate with: make blueprint-render BLUEPRINT=docker-compose
#
# Deploys Docker Compose stacks to docker hosts.
# Each host runs its own GitLab Runner (deployed via gitlab_runner role),
# so deploy jobs execute locally on the target host — no SSH required.
#
# Runner tags per host: [<hostname>]
# All jobs target the hostname tag to ensure they run on the correct host.

stages:
  - validate
  - deploy

variables:
  COMPOSE_BASE_DIR: "{{ blueprint_repo_context.compose_base_dir }}"

# -----------------------------------------------
# Validate compose file syntax
# Runs on the first docker host's runner
# -----------------------------------------------
validate:
  stage: validate
  script:
    - |
      echo "=== Validating Docker Compose files ==="
      errors=0
      for compose_file in $(find hosts/ -type f \( -name 'docker-compose.yml' -o -name 'docker-compose.yaml' -o -name 'compose.yml' -o -name 'compose.yaml' \) 2>/dev/null); do
        echo "  Checking: ${compose_file}"
        if docker compose -f "${compose_file}" config --quiet 2>&1; then
          echo "    ✓ Valid"
        else
          echo "    ✗ Invalid"
          errors=$((errors + 1))
        fi
      done
      if [ "${errors}" -eq 0 ]; then
        echo "✓ All compose files valid"
      else
        echo "✗ ${errors} file(s) failed validation"
        exit 1
      fi
  rules:
    - changes:
        - "hosts/**/*"
  tags:
    - "{{ (blueprint_repo_context.all_hosts | first) }}"
  allow_failure: true

# -----------------------------------------------
# Base deploy job (extended by per-host jobs)
# -----------------------------------------------
# Runs LOCALLY on the host's own GitLab Runner.
# The runner tag matching the hostname ensures the job
# lands on the correct machine.
.deploy_base:
  stage: deploy
  before_script:
    - apk add --no-cache rsync || apt-get install -y rsync || true
  script:
    - |
      echo "=========================================="
      echo " Docker Compose Deploy — ${HOST_NAME}"
      echo " Compose dir: ${COMPOSE_BASE_DIR}"
      echo "=========================================="

      # Ensure compose base directory exists
      mkdir -p "${COMPOSE_BASE_DIR}"

      # Count deployable files (skip README/.gitkeep)
      file_count=$(find "hosts/${HOST_NAME}" -type f \
        ! -name 'README.md' ! -name '.gitkeep' ! -name '.gitignore' | wc -l)

      if [ "${file_count}" -eq 0 ]; then
        echo "INFO: No compose files in hosts/${HOST_NAME}/, nothing to deploy"
        exit 0
      fi

      echo "Files to sync: ${file_count}"

      # Sync compose stacks to the local compose directory
      # --delete removes stacks that were removed from the repo
      rsync -rlpt --delete \
        --exclude='.gitkeep' \
        --exclude='README.md' \
        --exclude='.gitignore' \
        "hosts/${HOST_NAME}/" \
        "${COMPOSE_BASE_DIR}/"

      # Start/update all compose stacks
      cd "${COMPOSE_BASE_DIR}"
      started=0; failed=0; skipped=0

      for stack_dir in */; do
        [ -d "${stack_dir}" ] || continue
        stack_name="${stack_dir%/}"

        # Find compose file
        compose_file=""
        for f in docker-compose.yml docker-compose.yaml compose.yml compose.yaml; do
          if [ -f "${stack_dir}${f}" ]; then
            compose_file="${stack_dir}${f}"
            break
          fi
        done

        if [ -z "${compose_file}" ]; then
          echo "  ⚠ ${stack_name}: no compose file found, skipping"
          skipped=$((skipped + 1))
          continue
        fi

        echo "  ▶ ${stack_name}"
        if docker compose -f "${compose_file}" up -d --remove-orphans 2>&1; then
          started=$((started + 1))
        else
          echo "    ✗ Failed to start ${stack_name}"
          failed=$((failed + 1))
        fi
      done

      echo ""
      echo "=========================================="
      echo " Results: ${started} started, ${failed} failed, ${skipped} skipped"
      echo "=========================================="
      docker ps --format 'table {{"{{"}}.Names{{"}}"}}\t{{"{{"}}.Status{{"}}"}}\t{{"{{"}}.Ports{{"}}"}}' 2>/dev/null || true

      [ "${failed}" -eq 0 ] || exit 1

# -----------------------------------------------
# Per-host deploy jobs
# Generated from Ansible inventory ({{ blueprint_repo_context.all_hosts | length }} docker host{{ 's' if blueprint_repo_context.all_hosts | length != 1 else '' }})
# Each job runs on the host's own runner via the hostname tag.
# -----------------------------------------------
{% for host_name, host_config in blueprint_repo_context.all_hosts.items() %}
deploy-{{ host_name }}:
  extends: .deploy_base
  variables:
    HOST_NAME: "{{ host_name }}"
  rules:
    - changes:
        - "hosts/{{ host_name }}/**/*"
    - when: manual
      allow_failure: true
  tags:
    - "{{ host_name }}"
  environment:
    name: "{{ host_name }}"
    url: "http://{{ host_config.ip_address }}"
{% endfor %}
