{#
Template: configuration.nix.j2
Purpose: Generate per-host NixOS configuration.nix files from Ansible inventory
Blueprint: nix-flakes
Context: blueprint_host_context (contains host_name, host_config, repo_context)
#}
# NixOS Configuration for {{ blueprint_host_context.host_name }}
# Generated by Ansible blueprint_repo role — DO NOT EDIT MANUALLY
# Source: inventory/{{ blueprint_host_context.repo_context.env }}/host_vars/{{ blueprint_host_context.host_name }}.yml
# Regenerate: make blueprint-render BLUEPRINT=nix-flakes

{ config, lib, pkgs, hostname, inputs, ... }:

{% set vm_config = blueprint_host_context.host_config %}
{% set vm_name = blueprint_host_context.host_name %}
{% set nixos_role_file = vm_config.nixos_template | default('') | regex_replace('-vm$', '') %}
{
imports = [
{% if nixos_role_file %}
./{{ nixos_role_file }}.nix
{% endif %}
# Hardware configuration (auto-detected on first boot)
# ./hardware-configuration.nix
];

# =============================================
# Network Configuration
# =============================================
networking.hostName = "{{ vm_name }}";
networking.domain = "{{ blueprint_host_context.repo_context.domain | default('example.lan') }}";

{% set iface = vm_config.network_interface | default('ens18') %}
networking.interfaces.{{ iface }} = {
useDHCP = false;
ipv4.addresses = [{
address = "{{ vm_config.ip_address }}";
prefixLength = {{ vm_config.cidr | default(24) }};
}];
};

{% if vm_config.gateway is defined %}
{% set gw = vm_config.gateway %}
{% elif blueprint_host_context.repo_context.subnets is defined and vm_config.subnet_key is defined and
blueprint_host_context.repo_context.subnets[vm_config.subnet_key] is defined and
blueprint_host_context.repo_context.subnets[vm_config.subnet_key].gateway is defined %}
{% set gw = blueprint_host_context.repo_context.subnets[vm_config.subnet_key].gateway %}
{% else %}
{% set gw = blueprint_host_context.repo_context.default_gateway | default('10.0.0.1') %}
{% endif %}
networking.defaultGateway = {
address = "{{ gw }}";
interface = "{{ iface }}";
};

{% if vm_config.dns_servers is defined %}
networking.nameservers = [
{% for dns in vm_config.dns_servers %}
"{{ dns }}"
{% endfor %}
];
{% elif blueprint_host_context.repo_context.subnets is defined and vm_config.subnet_key is defined and
blueprint_host_context.repo_context.subnets[vm_config.subnet_key] is defined %}
{% set subnet = blueprint_host_context.repo_context.subnets[vm_config.subnet_key] %}
{% if subnet.dns_servers is defined %}
networking.nameservers = [
{% for dns in subnet.dns_servers %}
"{{ dns }}"
{% endfor %}
];
{% else %}
networking.nameservers = [ "1.1.1.1" "8.8.8.8" ];
{% endif %}
{% else %}
networking.nameservers = [ "{{ blueprint_host_context.repo_context.dns_servers[0] | default('1.1.1.1') }}" "1.1.1.1" ];
{% endif %}

# =============================================
# Service Modules
# =============================================
{% if vm_config.iac_services is defined %}
iac = {
{% for service, service_config in vm_config.iac_services.items() %}
{{ service }} = {
{% if service_config is mapping %}
{% for key, value in service_config.items() %}
{% if value is boolean %}
{{ key }} = {{ value | lower }};
{% elif value is number %}
{{ key }} = {{ value }};
{% elif value is string %}
{{ key }} = "{{ value }}";
{% elif value is sequence and value is not string %}
{{ key }} = [
{% for item in value %}
"{{ item }}"
{% endfor %}
];
{% endif %}
{% endfor %}
{% elif service_config is boolean %}
enable = {{ service_config | lower }};
{% endif %}
};
{% endfor %}
};
{% else %}
iac = {
base.enable = true;
monitoring.enable = true;
backup = {
enable = true;
repository = "s3:s3.amazonaws.com/iac-backups/${{ '{' }}config.networking.hostName}";
schedule = "daily";
paths = [
"/etc/nixos"
"/var/lib"
];
};
};
{% endif %}

# =============================================
# Virtualization (Docker/Podman)
# =============================================
{% if vm_config.enable_docker | default(false) %}
virtualisation.docker = {
enable = true;
autoPrune = {
enable = true;
dates = "weekly";
};
};
{% endif %}

{% if vm_config.enable_podman | default(false) %}
virtualisation.podman = {
enable = false;
dockerCompat = {{ vm_config.podman_docker_compat | default(true) | lower }};
};
{% endif %}

# =============================================
# System Packages
# =============================================
environment.systemPackages = with pkgs; [
# Standard tools
python3
{% if vm_config.additional_packages is defined %}

# Additional packages for {{ vm_name }}
{% for package in vm_config.additional_packages %}
{% if '-' in package %}
pkgs."{{ package }}"
{% else %}
{{ package }}
{% endif %}
{% endfor %}
{% endif %}
];

# =============================================
# Users
# =============================================
{% if vm_config.nixos_users is defined %}
{% for username, user_config in vm_config.nixos_users.items() %}
users.users.{{ username }} = {
isNormalUser = true;
{% if user_config.extra_groups is defined %}
extraGroups = [
{% for group in user_config.extra_groups %}
"{{ group }}"
{% endfor %}
];
{% else %}
extraGroups = [ "wheel" "systemd-journal" ];
{% endif %}
{% if user_config.ssh_keys is defined %}
openssh.authorizedKeys.keys = [
{% for key in user_config.ssh_keys %}
"{{ key }}"
{% endfor %}
];
{% endif %}
};
{% endfor %}
{% else %}
users.users.{{ vm_config.ciuser | default(blueprint_host_context.repo_context.service_user | default('ansible')) }} = {
isNormalUser = true;
extraGroups = [ "wheel" "systemd-journal"{{ ' "docker"' if vm_config.enable_docker | default(false) else '' }} ];
openssh.authorizedKeys.keys = [
# SSH keys managed via SOPS or cloud-init
];
};
{% endif %}

# =============================================
# SOPS Secrets Management
# =============================================
sops = {
defaultSopsFile = ../../secrets/secrets.yaml;

# Use ONLY the dedicated age key file (provisioned by Ansible)
age.keyFile = "/var/lib/sops-nix/key.txt";
age.sshKeyPaths = [];
gnupg.sshKeyPaths = [];

secrets = {
{% if vm_config.sops_secrets is defined %}
{% for secret, secret_config in vm_config.sops_secrets.items() %}
{{ secret }} = {
{% if secret_config is mapping %}
{% for key, value in secret_config.items() %}
{{ key }} = "{{ value }}";
{% endfor %}
{% else %}
owner = "root";
{% endif %}
};
{% endfor %}
{% else %}
# Default secrets (add more as needed)
# restic-password = { owner = "root"; };
{% endif %}
};
};

{% if vm_config.firewall_tcp_ports is defined or vm_config.firewall_udp_ports is defined %}
# =============================================
# Firewall Configuration (enabled in modules/base.nix)
# =============================================
networking.firewall = {
{% if vm_config.firewall_tcp_ports is defined %}
allowedTCPPorts = [
{% for port in vm_config.firewall_tcp_ports %}
{{ port }}
{% endfor %}
];
{% endif %}
{% if vm_config.firewall_udp_ports is defined %}
allowedUDPPorts = [
{% for port in vm_config.firewall_udp_ports %}
{{ port }}
{% endfor %}
];
{% endif %}
};
{% endif %}

{% if vm_config.description is defined %}
# Description: {{ vm_config.description }}
{% endif %}
{% if vm_config.tags is defined %}
# Tags: {{ vm_config.tags | join(', ') }}
{% endif %}

# System state version (do not change after initial setup)
system.stateVersion = "{{ vm_config.nixos_state_version | default('25.11') }}";
}
