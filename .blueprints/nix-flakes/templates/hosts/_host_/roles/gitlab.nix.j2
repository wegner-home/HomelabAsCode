{#
Template: gitlab.nix.j2
Purpose: GitLab NixOS service module with nginx, PostgreSQL, Redis, Registry
Blueprint: nix-flakes
Context: blueprint_host_context (host_name, host_config, repo_context)
#}
{ config, pkgs, lib, ... }:

{% set vm_config = blueprint_host_context.host_config %}
{% set vm_name = blueprint_host_context.host_name %}
{% set gitlab_domain = blueprint_host_context.repo_context.domain %}
{% set gitlab_fqdn = vm_config.gitlab_fqdn | default(vm_name + '.' + gitlab_domain) %}
{% set gitlab_ssl_enable = vm_config.gitlab_ssl_enable | default(true) %}
{% set gitlab_sops_enable = vm_config.gitlab_sops_enable | default(true) %}
{% set gitlab_https_port = vm_config.gitlab_https_port | default(443) %}
{% set gitlab_http_port = vm_config.gitlab_http_port | default(80) %}
{% set gitlab_data_dir = vm_config.gitlab_data_dir | default('/var/lib/gitlab') %}
{% set gitlab_backup_dir = vm_config.gitlab_backup_dir | default('/var/lib/gitlab/backups') %}
{% set gitlab_root_email = vm_config.gitlab_root_email | default('admin@' + gitlab_domain) %}
{% set gitlab_signup_enabled = vm_config.gitlab_signup_enabled | default(false) %}
{% set gitlab_enable_registry = vm_config.gitlab_enable_registry | default(true) %}
{% set gitlab_registry_port = vm_config.gitlab_registry_port | default(5050) %}
{% set gitlab_enable_lfs = vm_config.gitlab_enable_lfs | default(true) %}
{% set gitlab_enable_pages = vm_config.gitlab_enable_pages | default(false) %}
{% set gitlab_enable_prometheus = vm_config.gitlab_enable_prometheus | default(true) %}
{% set gitlab_prometheus_port = vm_config.gitlab_prometheus_port | default(9090) %}
{% set gitlab_puma_worker_processes = vm_config.gitlab_puma_worker_processes | default(2) %}
{% set gitlab_sidekiq_concurrency = vm_config.gitlab_sidekiq_concurrency | default(10) %}
{% set gitlab_smtp_enable = vm_config.gitlab_smtp_enable | default(false) %}
{% set gitlab_ssl_certificate = vm_config.gitlab_ssl_certificate | default('/var/lib/gitlab/ssl/gitlab.crt') %}
{% set gitlab_ssl_certificate_key = vm_config.gitlab_ssl_certificate_key | default('/var/lib/gitlab/ssl/gitlab.key') %}
{% set _dns_hostnames = vm_config.dns_hostnames | default([]) %}
{% set gitlab_runner_enable = vm_config.gitlab_runner_enable | default(false) %}
{% set gitlab_backup_enable = vm_config.gitlab_backup_enable | default(true) %}
{% set gitlab_backup_schedule = vm_config.gitlab_backup_schedule | default('02:00') %}
{% set gitlab_backup_skip = vm_config.gitlab_backup_skip | default(['uploads']) %}
{% set gitlab_backup_retention = vm_config.gitlab_backup_retention | default(7) %}
{
# GitLab service configuration module
# Generated by Ansible blueprint_repo role — DO NOT EDIT MANUALLY
# Source: inventory/{{ blueprint_host_context.repo_context.env }}/host_vars/{{ vm_name }}.yml
# Regenerate: make blueprint-render BLUEPRINT=nix-flakes

# ===============================================
# GitLab CE/EE Configuration
# ===============================================
services.gitlab = {
enable = true;

# Basic settings
host = "{{ gitlab_fqdn }}";
port = {{ gitlab_https_port if gitlab_ssl_enable else gitlab_http_port }};
https = {{ gitlab_ssl_enable | lower }};

# User and group
user = "gitlab";
group = "gitlab";

# Initial root password
{% if gitlab_sops_enable %}
initialRootPasswordFile = config.sops.secrets.gitlab-root-password.path;
{% else %}
initialRootPasswordFile = pkgs.writeText "gitlab-root-password" "{{ vm_config.gitlab_root_password | default('changeme')
}}";
{% endif %}

# Paths
statePath = "{{ gitlab_data_dir }}";
backup.path = "{{ gitlab_backup_dir }}";

# Secrets
{% if gitlab_sops_enable %}
databasePasswordFile = config.sops.secrets.gitlab-db-password.path;
secrets = {
dbFile = config.sops.secrets.gitlab-db-secret.path;
secretFile = config.sops.secrets.gitlab-secret.path;
otpFile = config.sops.secrets.gitlab-otp.path;
jwsFile = config.sops.secrets.gitlab-jws.path;
# ActiveRecord encryption keys (required for GitLab 18+)
activeRecordPrimaryKeyFile = config.sops.secrets.gitlab-ar-primary.path;
activeRecordDeterministicKeyFile = config.sops.secrets.gitlab-ar-deterministic.path;
activeRecordSaltFile = config.sops.secrets.gitlab-ar-salt.path;
};
{% else %}
secrets = {
dbFile = pkgs.writeText "gitlab-db-secret" "changeme-db-secret";
secretFile = pkgs.writeText "gitlab-secret" "changeme-secret-key-base";
otpFile = pkgs.writeText "gitlab-otp-secret" "changeme-otp-key-base";
jwsFile = pkgs.writeText "gitlab-jws-secret" "changeme-jws-private-key";
};
{% endif %}

{% if gitlab_smtp_enable %}
# SMTP Configuration
smtp = {
enable = true;
address = "{{ vm_config.gitlab_smtp_address }}";
port = {{ vm_config.gitlab_smtp_port }};
username = "{{ vm_config.gitlab_smtp_user_name }}";
{% if gitlab_sops_enable %}
passwordFile = config.sops.secrets.gitlab-smtp-password.path;
{% else %}
passwordFile = pkgs.writeText "gitlab-smtp-password" "{{ vm_config.gitlab_smtp_password }}";
{% endif %}
domain = "{{ vm_config.gitlab_smtp_domain }}";
authentication = "{{ vm_config.gitlab_smtp_authentication }}";
enableStartTLSAuto = {{ vm_config.gitlab_smtp_enable_starttls_auto | lower }};
tls = {{ vm_config.gitlab_smtp_tls | lower }};
opensslVerifyMode = "{{ vm_config.gitlab_smtp_openssl_verify_mode }}";
};
{% endif %}

# Extra configuration
extraConfig = {
gitlab = {
email_from = "{{ gitlab_root_email }}";
email_display_name = "GitLab @ {{ gitlab_domain }}";
email_reply_to = "{{ gitlab_root_email }}";
signup_enabled = {{ gitlab_signup_enabled | lower }};
default_projects_features = {
issues = true;
merge_requests = true;
wiki = true;
snippets = true;
builds = true;
container_registry = {{ gitlab_enable_registry | lower }};
};
};

{% if gitlab_enable_lfs %}
lfs = {
enabled = true;
};
{% endif %}

{% if gitlab_enable_pages %}
pages = {
enabled = true;
};
{% endif %}

{% if gitlab_enable_prometheus %}
prometheus = {
enable = true;
listen_address = "localhost:{{ gitlab_prometheus_port }}";
};
{% endif %}
};

# Performance settings
puma.workers = {{ gitlab_puma_worker_processes }};
sidekiq.concurrency = {{ gitlab_sidekiq_concurrency }};
};

{% if gitlab_enable_registry %}
# GitLab Registry (JWT auth certs auto-generated by nixpkgs gitlab-registry-cert service)
services.gitlab.registry = {
enable = true;
externalAddress = "registry.{{ gitlab_fqdn }}";
externalPort = {{ gitlab_registry_port }};
certFile = "{{ gitlab_data_dir }}/registry/gitlab-registry.crt";
keyFile = "{{ gitlab_data_dir }}/registry/gitlab-registry.key";
};

# docker-registry needs gitlab group to traverse /var/lib/gitlab/ (0750) and read JWT cert
systemd.services.docker-registry.serviceConfig.SupplementaryGroups = [ "gitlab" ];
{% endif %}

# nginx needs gitlab group to traverse /var/lib/gitlab/ (0750) and read SSL certs
systemd.services.nginx.serviceConfig.SupplementaryGroups = [ "gitlab" ];

{% if gitlab_ssl_enable %}
# ===============================================
# SSL/TLS — Nginx Reverse Proxy
# ===============================================
systemd.services.gitlab-ensure-cert = {
description = "Ensure SSL certificate exists for GitLab";
wantedBy = [ "multi-user.target" ];
before = [ "nginx.service" ];
requiredBy = [ "nginx.service" ];
serviceConfig = {
Type = "oneshot";
RemainAfterExit = true;
};
path = [ pkgs.openssl ];
script = ''
CERT="{{ gitlab_ssl_certificate }}"
KEY="{{ gitlab_ssl_certificate_key }}"
LOCAL_CERT="/etc/nixos/secrets/gitlab-ssl-cert.crt"
LOCAL_KEY="/etc/nixos/secrets/gitlab-ssl-cert.key"

# If both cert and key already exist at the target path, nothing to do
if [ -f "$CERT" ] && [ -f "$KEY" ]; then
echo "SSL certificate already exists at $CERT"
exit 0
fi

mkdir -p "$(dirname "$CERT")"

# If a local certificate was provided in the flake, use it
if [ -f "$LOCAL_CERT" ] && [ -f "$LOCAL_KEY" ]; then
echo "Using local certificate from $LOCAL_CERT"
cp "$LOCAL_CERT" "$CERT"
cp "$LOCAL_KEY" "$KEY"
chmod 640 "$KEY"
chmod 644 "$CERT"
chown root:nginx "$KEY"
echo "Local certificate installed for {{ gitlab_fqdn }}"
exit 0
fi

echo "No certificate found — generating self-signed certificate"
openssl req -x509 -newkey rsa:4096 \
-keyout "$KEY" \
-out "$CERT" \
-sha256 -days 3650 -nodes \
-subj "/CN={{ gitlab_fqdn }}" \
-addext "subjectAltName=DNS:{{ gitlab_fqdn }},DNS:registry.{{ gitlab_fqdn }}{% for alias in _dns_hostnames %}{% set a =
alias if '.' in alias else alias + '.' + gitlab_domain %}{% if a != gitlab_fqdn and a != 'registry.' + gitlab_fqdn
%},DNS:{{ a }}{% endif %}{% endfor %}"
chmod 640 "$KEY"
chmod 644 "$CERT"
chown root:nginx "$KEY"
echo "Self-signed certificate generated for {{ gitlab_fqdn }}"
'';
};

services.nginx = {
enable = true;
recommendedProxySettings = true;
recommendedTlsSettings = true;

# GitLab web UI / API
virtualHosts."{{ gitlab_fqdn }}" = {
forceSSL = true;
{% set _aliases = [] %}
{% for alias in _dns_hostnames %}
{% set a = alias if '.' in alias else alias + '.' + gitlab_domain %}
{% if a != gitlab_fqdn and _aliases.append(a) %}{% endif %}
{% endfor %}
{% if _aliases %}
serverAliases = [ {% for a in _aliases %}"{{ a }}" {% endfor %}];
{% endif %}
sslCertificate = "{{ gitlab_ssl_certificate }}";
sslCertificateKey = "{{ gitlab_ssl_certificate_key }}";
locations."/" = {
proxyPass = "http://unix:/run/gitlab/gitlab-workhorse.socket";
proxyWebsockets = true;
extraConfig = ''
client_max_body_size 0;
proxy_read_timeout 3600;
proxy_connect_timeout 300;
'';
};
};

{% if gitlab_enable_registry %}
# Container registry
virtualHosts."registry.{{ gitlab_fqdn }}" = {
forceSSL = true;
sslCertificate = "{{ gitlab_ssl_certificate }}";
sslCertificateKey = "{{ gitlab_ssl_certificate_key }}";
locations."/" = {
proxyPass = "http://127.0.0.1:{{ gitlab_registry_port }}";
extraConfig = ''
client_max_body_size 0;
chunked_transfer_encoding on;
'';
};
};
{% endif %}
};
{% endif %}

# ===============================================
# PostgreSQL Configuration
# ===============================================
services.postgresql = {
enable = true;
ensureDatabases = [ "gitlab" ];
ensureUsers = [
{
name = "gitlab";
ensureDBOwnership = true;
}
];
settings = {
shared_buffers = "{{ vm_config.gitlab_postgresql_shared_buffers | default('256MB') }}";
max_connections = {{ vm_config.gitlab_postgresql_max_connections | default(200) }};
};
};

# ===============================================
# Redis Configuration
# ===============================================
services.redis.servers.gitlab = {
enable = true;
port = 0; # Unix socket only (recommended)
};

{% if gitlab_runner_enable %}
# ===============================================
# GitLab Runner Configuration
# ===============================================
services.gitlab-runner = {
enable = true;
settings = {
concurrent = {{ vm_config.gitlab_runner_count | default(2) }};
};
services = {
default = {
registrationConfigFile = "/var/lib/gitlab-runner/.runner-token";
dockerImage = "{{ vm_config.gitlab_runner_docker_image | default('docker:latest') }}";
executor = "{{ vm_config.gitlab_runner_executor | default('shell') }}";
{% set _runner_tags = vm_config.gitlab_runner_tags | default([vm_name]) %}
tagList = [{% for tag in _runner_tags | unique %}"{{ tag }}"{% if not loop.last %} {% endif %}{% endfor %}];
};
};
};

# Docker support for runners
virtualisation.docker = {
enable = true;
autoPrune.enable = true;
};
{% endif %}

{% if gitlab_backup_enable %}
# ===============================================
# Backup Configuration (uses nixpkgs built-in gitlab-backup service)
# ===============================================
services.gitlab.backup = {
startAt = "{{ gitlab_backup_schedule }}";
{% if gitlab_backup_skip | length > 0 %}
skip = [{% for s in gitlab_backup_skip %} "{{ s }}"{% endfor %} ];
{% endif %}
keepTime = {{ gitlab_backup_retention | int * 24 }}; # hours ({{ gitlab_backup_retention }} days)
};
{% endif %}

# ===============================================
# Firewall — open ports for GitLab services
# ===============================================
networking.firewall.allowedTCPPorts = [
{{ gitlab_http_port }} # HTTP (redirect to HTTPS)
{{ gitlab_https_port }} # HTTPS (GitLab web UI + API)
{% if gitlab_enable_registry %}
{{ gitlab_registry_port }} # Container registry
{% endif %}
];

{% if gitlab_sops_enable %}
# ===============================================
# SOPS Secret Declarations (consumed by services above)
# ===============================================
sops.secrets = {
gitlab-root-password = {
owner = "gitlab";
group = "gitlab";
mode = "0400";
};
gitlab-db-password = {
owner = "gitlab";
group = "gitlab";
mode = "0400";
};
gitlab-db-secret = {
owner = "gitlab";
group = "gitlab";
mode = "0400";
};
gitlab-secret = {
owner = "gitlab";
group = "gitlab";
mode = "0400";
};
gitlab-otp = {
owner = "gitlab";
group = "gitlab";
mode = "0400";
};
gitlab-jws = {
owner = "gitlab";
group = "gitlab";
mode = "0400";
};
gitlab-ar-primary = {
owner = "gitlab";
group = "gitlab";
mode = "0400";
};
gitlab-ar-deterministic = {
owner = "gitlab";
group = "gitlab";
mode = "0400";
};
gitlab-ar-salt = {
owner = "gitlab";
group = "gitlab";
mode = "0400";
};
{% if gitlab_smtp_enable %}
gitlab-smtp-password = {
owner = "gitlab";
group = "gitlab";
mode = "0400";
};
{% endif %}
};
{% endif %}
}
