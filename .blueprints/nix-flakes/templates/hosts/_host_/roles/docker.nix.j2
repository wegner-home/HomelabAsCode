{#
Template: docker.nix.j2
Purpose: Docker host service module — Docker daemon, compose, cAdvisor, optional Traefik/Portainer
Blueprint: nix-flakes
Context: blueprint_host_context (host_name, host_config, repo_context)
#}
{ config, pkgs, lib, ... }:

{% set vm_config = blueprint_host_context.host_config %}
{% set vm_name = blueprint_host_context.host_name %}
{% set docker_prune_schedule = vm_config.docker_prune_schedule | default('weekly') %}
{% set docker_prune_keep_tagged = vm_config.docker_prune_keep_tagged | default(true) %}
{% set docker_storage_driver = vm_config.docker_storage_driver | default(none) %}
{% set docker_log_driver = vm_config.docker_log_driver | default('json-file') %}
{% set docker_log_max_size = vm_config.docker_log_max_size | default('10m') %}
{% set docker_log_max_file = vm_config.docker_log_max_file | default('3') %}
{% set docker_metrics_enable = vm_config.docker_metrics_enable | default(true) %}
{% set docker_metrics_port = vm_config.docker_metrics_port | default(9323) %}
{% set docker_insecure_registries = vm_config.docker_insecure_registries | default([]) %}
{% set docker_registry_mirrors = vm_config.docker_registry_mirrors | default([]) %}
{% set docker_enable_monitoring = vm_config.docker_enable_monitoring | default(true) %}
{% set docker_enable_backup = vm_config.docker_enable_backup | default(true) %}
{% set docker_backup_repository = vm_config.docker_backup_repository | default('s3:s3.amazonaws.com/iac-backups/' + vm_name) %}
{% set docker_backup_schedule = vm_config.docker_backup_schedule | default('daily') %}
{% set docker_backup_paths = vm_config.docker_backup_paths | default(['/opt/docker-compose', '/var/lib/docker/volumes']) %}
{% set docker_compose_enable = vm_config.docker_compose_enable | default(true) %}
{% set docker_compose_base_dir = vm_config.docker_compose_base_dir | default('/opt/docker-compose') %}
{% set docker_cadvisor_enable = vm_config.docker_cadvisor_enable | default(true) %}
{% set docker_cadvisor_port = vm_config.docker_cadvisor_port | default(8080) %}
{% set docker_traefik_enable = vm_config.docker_traefik_enable | default(false) %}
{% set docker_portainer_enable = vm_config.docker_portainer_enable | default(false) %}
{% set gitlab_runner_enable = vm_config.gitlab_runner_enable | default(false) %}
{
  # Docker host service configuration
  # Generated by Ansible blueprint_repo role — DO NOT EDIT MANUALLY
  # Source: inventory/{{ blueprint_host_context.repo_context.env }}/host_vars/{{ vm_name }}.yml
  # Regenerate: make blueprint-render BLUEPRINT=nix-flakes

  # ===============================================
  # Docker Engine
  # ===============================================
  virtualisation.oci-containers.backend = "docker";

  virtualisation.docker = {
    enable = true;

    autoPrune = {
      enable = true;
      dates = "{{ docker_prune_schedule }}";
{% if docker_prune_keep_tagged %}
      flags = [ "--filter" "until=168h" ];
{% endif %}
    };

{% if docker_storage_driver %}
    daemon.settings = {
      storage-driver = "{{ docker_storage_driver }}";
      log-driver = "{{ docker_log_driver }}";
      log-opts = {
        max-size = "{{ docker_log_max_size }}";
        max-file = "{{ docker_log_max_file }}";
      };
{% if docker_metrics_enable %}
      metrics-addr = "0.0.0.0:{{ docker_metrics_port }}";
{% endif %}
{% if docker_insecure_registries | length > 0 %}
      insecure-registries = [
{% for reg in docker_insecure_registries %}
        "{{ reg }}"
{% endfor %}
      ];
{% endif %}
{% if docker_registry_mirrors | length > 0 %}
      registry-mirrors = [
{% for mirror in docker_registry_mirrors %}
        "{{ mirror }}"
{% endfor %}
      ];
{% endif %}
    };
{% endif %}
  };

  # ===============================================
  # iac Service Modules
  # ===============================================
  iac = {
    base.enable = true;

{% if docker_enable_monitoring %}
    monitoring.enable = true;
{% endif %}

{% if docker_enable_backup %}
    backup = {
      enable = true;
      repository = "{{ docker_backup_repository }}";
      schedule = "{{ docker_backup_schedule }}";
      paths = [
{% for path in docker_backup_paths %}
        "{{ path }}"
{% endfor %}
      ];
    };
{% endif %}

{% if gitlab_runner_enable %}
    ci-runner = {
      enable = true;
      executor = "{{ vm_config.docker_gitlab_runner_executor | default('docker') }}";
      gitlabUrl = "{{ vm_config.gitlab_external_url | default('https://git.' + blueprint_host_context.repo_context.domain) }}";
      registrationTokenFile = "/var/lib/gitlab-runner/.runner-token";
      concurrent = {{ vm_config.gitlab_runner_concurrent | default(2) }};
      tags = [ "nixos" "docker" "{{ vm_name }}" ];
      dockerImage = "{{ vm_config.docker_gitlab_runner_docker_image | default('docker:latest') }}";
      dockerPrivileged = true;
      dockerVolumes = [
{% for vol in vm_config.docker_gitlab_runner_docker_volumes | default(['/var/run/docker.sock:/var/run/docker.sock']) %}
        "{{ vol }}"
{% endfor %}
      ];
      tlsVerify = {{ 'false' if vm_config.gitlab_ssl_self_signed | default(false) else 'true' }};
    };
{% endif %}
  };

{% if docker_compose_enable %}
  # ===============================================
  # Docker Compose Projects Directory
  # ===============================================
  systemd.tmpfiles.rules = [
    "d {{ docker_compose_base_dir }} 0755 root docker -"
  ];
{% endif %}

{% if docker_cadvisor_enable %}
  # ===============================================
  # cAdvisor — Container Metrics
  # ===============================================
  virtualisation.oci-containers.containers.cadvisor = {
    image = "gcr.io/cadvisor/cadvisor:latest";
    ports = [ "{{ docker_cadvisor_port }}:8080" ];
    volumes = [
      "/:/rootfs:ro"
      "/var/run:/var/run:ro"
      "/sys:/sys:ro"
      "/var/lib/docker/:/var/lib/docker:ro"
      "/dev/disk/:/dev/disk:ro"
    ];
    extraOptions = [ "--privileged" "--device=/dev/kmsg" ];
  };
{% endif %}

{% if docker_traefik_enable %}
  # ===============================================
  # Traefik Reverse Proxy
  # ===============================================
  virtualisation.oci-containers.containers.traefik = {
    image = "traefik:{{ vm_config.docker_traefik_version | default('latest') }}";
    ports = [
      "{{ vm_config.docker_traefik_http_port | default(80) }}:80"
      "{{ vm_config.docker_traefik_https_port | default(443) }}:443"
{% if vm_config.docker_traefik_dashboard_enable | default(true) %}
      "{{ vm_config.docker_traefik_dashboard_port | default(8081) }}:8080"
{% endif %}
    ];
    volumes = [
      "/var/run/docker.sock:/var/run/docker.sock:ro"
      "{{ docker_compose_base_dir }}/traefik:/etc/traefik"
    ];
    environment = {
      TRAEFIK_API_DASHBOARD = "{{ vm_config.docker_traefik_dashboard_enable | default(true) | lower }}";
      TRAEFIK_ENTRYPOINTS_WEB_ADDRESS = ":80";
      TRAEFIK_ENTRYPOINTS_WEBSECURE_ADDRESS = ":443";
      TRAEFIK_PROVIDERS_DOCKER = "true";
      TRAEFIK_PROVIDERS_DOCKER_EXPOSEDBYDEFAULT = "false";
    };
  };
{% endif %}

{% if docker_portainer_enable %}
  # ===============================================
  # Portainer Management UI
  # ===============================================
  virtualisation.oci-containers.containers.portainer = {
    image = "portainer/portainer-ce:{{ vm_config.docker_portainer_version | default('latest') }}";
    ports = [ "{{ vm_config.docker_portainer_port | default(9000) }}:9000" ];
    volumes = [
      "/var/run/docker.sock:/var/run/docker.sock"
      "{{ vm_config.docker_portainer_data_dir | default('/opt/portainer/data') }}:/data"
    ];
  };

  systemd.tmpfiles.rules = lib.mkAfter [
    "d {{ vm_config.docker_portainer_data_dir | default('/opt/portainer/data') }} 0755 root root -"
  ];
{% endif %}

  # ===============================================
  # Shell Aliases for Docker Operations
  # ===============================================
  programs.bash.interactiveShellInit = ''
    # Docker aliases
    alias dc='docker compose'
    alias dps='docker ps --format "table {{"{{"}}.Names{{"}}"}}\t{{"{{"}}.Status{{"}}"}}\t{{"{{"}}.Ports{{"}}"}}"'
    alias dlog='docker logs -f'
    alias dex='docker exec -it'
    alias dprune='docker system prune -af --volumes'
    alias lzd='lazydocker'
  '';
}
