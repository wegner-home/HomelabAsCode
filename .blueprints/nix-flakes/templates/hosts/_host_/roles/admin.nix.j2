{#
Template: admin.nix.j2
Purpose: Admin jumphost service module — SSH CA, management tools, infrastructure access
Blueprint: nix-flakes
Context: blueprint_host_context (host_name, host_config, repo_context)
#}
{ config, pkgs, lib, ... }:

{% set vm_config = blueprint_host_context.host_config %}
{% set vm_name = blueprint_host_context.host_name %}
{% set admin_ssh_ca_enable = vm_config.admin_ssh_ca_enable | default(true) %}
{% set admin_ssh_ca_dir = vm_config.admin_ssh_ca_dir | default('/etc/ssh-ca') %}
{% set admin_ssh_ca_user_cert_validity = vm_config.admin_ssh_ca_user_cert_validity | default('+52w') %}
{% set admin_ssh_ca_host_cert_validity = vm_config.admin_ssh_ca_host_cert_validity | default('+52w') %}
{% set admin_ssh_ca_allowed_principals = vm_config.admin_ssh_ca_allowed_principals | default([]) %}
{% set admin_enable_docker = vm_config.admin_enable_docker | default(false) %}
{% set admin_enable_monitoring = vm_config.admin_enable_monitoring | default(true) %}
{% set admin_enable_backup = vm_config.admin_enable_backup | default(true) %}
{% set admin_backup_repository = vm_config.admin_backup_repository | default('s3:s3.amazonaws.com/iac-backups/' + vm_name) %}
{% set admin_backup_schedule = vm_config.admin_backup_schedule | default('daily') %}
{% set admin_backup_paths = vm_config.admin_backup_paths | default(['/etc/nixos', '/etc/ssh-ca', '/home']) %}
{
  # Admin jumphost service configuration
  # Generated by Ansible blueprint_repo role — DO NOT EDIT MANUALLY
  # Source: inventory/{{ blueprint_host_context.repo_context.env }}/host_vars/{{ vm_name }}.yml
  # Regenerate: make blueprint-render BLUEPRINT=nix-flakes

{% if admin_ssh_ca_enable %}
  # ===============================================
  # SSH Certificate Authority
  # ===============================================
  # This admin VM manages SSH certificates for the infrastructure.
  # CA keys are stored in {{ admin_ssh_ca_dir }}.
  # User certs valid for: {{ admin_ssh_ca_user_cert_validity }}
  # Host certs valid for: {{ admin_ssh_ca_host_cert_validity }}

  # Ensure CA directory structure exists
  systemd.tmpfiles.rules = [
    "d {{ admin_ssh_ca_dir }} 0700 root root -"
    "d {{ admin_ssh_ca_dir }}/signed 0700 root root -"
  ];

  # Trust CA-signed host keys for outbound SSH
  programs.ssh.knownHostsFiles = lib.mkIf (builtins.pathExists {{ admin_ssh_ca_dir }}/ca_key.pub) [
    {{ admin_ssh_ca_dir }}/ca_key.pub
  ];

  # Accept CA-signed user keys for inbound SSH
  services.openssh.extraConfig = ''
    TrustedUserCAKeys {{ admin_ssh_ca_dir }}/ca_key.pub
{% for principal in admin_ssh_ca_allowed_principals %}
    AuthorizedPrincipalsFile {{ admin_ssh_ca_dir }}/principals/%u
{% endfor %}
  '';
{% endif %}

{% if admin_enable_docker %}
  # ===============================================
  # Docker (for management tools)
  # ===============================================
  virtualisation.docker = {
    enable = true;
    autoPrune = {
      enable = true;
      dates = "weekly";
    };
  };
{% endif %}

  # ===============================================
  # iac Service Modules
  # ===============================================
  iac = {
    base.enable = true;

{% if admin_enable_monitoring %}
    monitoring.enable = true;
{% endif %}

{% if admin_enable_backup %}
    backup = {
      enable = true;
      repository = "{{ admin_backup_repository }}";
      schedule = "{{ admin_backup_schedule }}";
      paths = [
{% for path in admin_backup_paths %}
        "{{ path }}"
{% endfor %}
      ];
    };
{% endif %}
  };

  # ===============================================
  # Shell Environment for Admin Operations
  # ===============================================
  programs.bash.interactiveShellInit = ''
    # iac admin aliases
    alias k='kubectl'
    alias tf='terraform'
    alias ap='ansible-playbook'
    alias ai='ansible-inventory'

{% if admin_ssh_ca_enable %}
    # SSH CA shortcuts
    alias ca-sign-user='{{ admin_ssh_ca_dir }}/sign-user-cert.sh'
    alias ca-sign-host='{{ admin_ssh_ca_dir }}/sign-host-cert.sh'
{% endif %}
  '';

{% if vm_config.admin_kubeconfig_path is defined %}
  # ===============================================
  # Kubernetes Configuration
  # ===============================================
  environment.variables.KUBECONFIG = "{{ vm_config.admin_kubeconfig_path }}";
{% endif %}
}
