**/.age-key.txt
**/key.txt
secrets/*.key

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Terraform state (if any)
*.tfstate
*.tfstate.backup
.terraform/

# Ansible retry files
*.retry
